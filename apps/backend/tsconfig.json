{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "../..",
    "paths": {
      "@contracts/*": ["../../contracts/*"],
      "@db/*": ["../../db/*"],
      "db/*": ["../../db/*"]
    }
  },
  "include": ["src", "../../api", "../../contracts", "../../db"]
}
